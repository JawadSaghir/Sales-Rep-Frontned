# ---------------------------------------------------------------------------
# Copy this file to .env.local (same folder as pyproject.toml) and fill in your
# own keys. NEVER commit .env.local or share it — these are secrets.
# ---------------------------------------------------------------------------

# LiveKit Cloud — create a project at https://cloud.livekit.io and copy these
# from the project's Settings > Keys page.
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# OpenRouter (LLM) — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key

# Deepgram (speech-to-text) — https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_key

# Cartesia (text-to-speech) — https://play.cartesia.ai (Account > API Keys)
CARTESIA_API_KEY=your_cartesia_key

# Mem0 (long-term memory) — https://app.mem0.ai
MEM0_API_KEY=your_mem0_key

# --- Rep Trainer ---
# Which character card the prospect loads (file stem in prompts/characters/).
PROSPECT_CHARACTER=burned_before_skeptic
# Fallback trainee id when the room/participant identity is unavailable (console/local dev).
REP_ID=unknown
